name: Keep Vercel Alive

on:
  schedule:
    # Chạy mỗi 15 phút, từ thứ 2 đến chủ nhật
    - cron: '*/15 * * * *'
  # Cho phép bạn bấm nút chạy thủ công trên GitHub nếu muốn
  workflow_dispatch:

jobs:
  ping:
    runs-on: ubuntu-latest
    steps:
      - name: Send ping request to Vercel
        run: |
          curl -I -s https://vercel.app
